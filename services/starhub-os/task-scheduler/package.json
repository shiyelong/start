    "uuid": "11.1.0"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "@types/node": "20.17.16",
    "@types/express": "5.0.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/uuid": "10.0.0",
    "vitest": "2.1.8",
    "fast-check": "4.6.0",
    "supertest": "7.1.0",
    "@types/supertest": "6.0.2",
    "eslint": "8.57.1",
    "tsx": "4.19.2"
